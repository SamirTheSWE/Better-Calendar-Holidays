    },
    "devDependencies": {
        "@angular-devkit/build-angular": "20.3.3",
        "@angular-eslint/builder": "20.4.0",
        "@angular-eslint/eslint-plugin": "20.4.0",
        "@angular-eslint/eslint-plugin-template": "20.4.0",
